<style>
  /* ── Reset & base ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    background: #f5f4f0;
    color: #2c2c2a;
    padding: 2rem;
    min-height: 100vh;
  }

  /* ── Page header ── */
  header {
    max-width: 900px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  header h1 {
    font-size: 20px;
    font-weight: 500;
    color: #2c2c2a;
  }
  header p {
    font-size: 13px;
    color: #5f5e5a;
  }

  /* ── Card wrapper ── */
  .card {
    max-width: 900px;
    margin: 0 auto;
    background: #fff;
    border-radius: 12px;
    border: 0.5px solid rgba(0,0,0,0.12);
    padding: 1.5rem;
    overflow-x: auto;
  }

  /* ── SVG nodes ── */
  .node { cursor: pointer; }
  .node:hover rect, .node:hover circle { opacity: 0.82; }

  /* ── Tooltip ── */
  #tooltip {
    position: fixed;
    background: #2c2c2a;
    color: #f5f4f0;
    font-size: 12px;
    padding: 6px 10px;
    border-radius: 6px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    max-width: 240px;
    line-height: 1.5;
    z-index: 999;
  }

  /* ── Legend ── */
  .legend {
    max-width: 800px;
    margin: 1rem auto 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 20px;
    font-size: 12px;
    color: #5f5e5a;
    align-items: center;
    padding: 0 0.25rem;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .legend-swatch {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .legend-line {
    width: 28px;
    height: 0;
    flex-shrink: 0;
  }

  /* ── Edit tip ── */
  .edit-tip {
    max-width: 900px;
    margin: 0.75rem auto 0;
    font-size: 11px;
    color: #888780;
  }
</style>
</head>
